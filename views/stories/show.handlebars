<h3 >{{story.title}} 
  
{{#if (editIcon story.userID user.id)}}
     <small> <a href='/stories/edit/{{story.id}}' class="btnhalfway-fab "><i
            class="fa-solid fa-pencil"></i></a>
            </small>
      {{/if}}

</h3>
<div class="row">
<div class="col s12 m8">
  <div class="card">
    <div class="card-content center-align">
      <span class="card-title">{{formatDate story.date 'MMMM do yyyy'}}</span>
      <p>{{stripTags story.body }}</p>
       <br>
        <div class="card-action">
          <a href="/stories/" class="btn grey">Back to Stories</a>
        </div>
    </div>
  </div>
 {{#if story.allowComments}}
  <div class="card">
    <div class="card-content">
      <span class="card-title">Comments</span>
      {{#if user}}
      <form action="/stories/comment/{{story.id}}" method="post">
      <div class="input-field">
        <textarea name="commentBody" id="commentBody" class="materialize-textarea"></textarea>
        <label for="commentBody">Add comment</label>
      </div>
      <input type="submit" value="Submit" class="btn">
      </form>
      {{else}}
  <p>Please <a href="/auth/google">Log</a> in to leave a comment</p>
  {{/if}}
    </div>
  </div>
    {{#each story.comments}}
  <div class="card">
    <div class="card-content">
      <h5>{{this.commentBody}}</h5>
       <div class="chip">
            <img src="{{this.commentUser.image}}" alt="author">
            {{this.commentUser.firstName}} {{this.commentUser.lastName}}
      </div>
      <br>
      <small>posted: {{formatDate this.commentDate 'MMMM do yyy'}}</small>
    </div>
  </div>
  {{/each}}

  {{/if}}
</div>
  <div class="col s12 m4">
    <div class="card">
      <div class="card-content">
      <span class="card-title center-align">{{story.firstName}} {{story.lastName}}</span>
      </div>
      <div class=" circle responsive-img">
        <img class="circle responsive-img" src="{{story.image}}" alt="image">
      </div>
      <div class="card-action center-align">
        <a href="/stories/user/{{story.userID}}" class="">More stories from {{story.firstName}}</a>
      </div>
    </div>
  </div>

</div>